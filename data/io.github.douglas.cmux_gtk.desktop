[Desktop Entry]
Name=cmux
GenericName=Terminal Multiplexer
Comment=Terminal multiplexer for AI coding agents
Exec=cmux-app %u
Icon=io.github.douglas.cmux_gtk
Terminal=false
Type=Application
Categories=System;TerminalEmulator;Development;
Keywords=terminal;multiplexer;browser;ai;coding;
StartupNotify=true
StartupWMClass=cmux-gtk
MimeType=x-scheme-handler/cmux;
